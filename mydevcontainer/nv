#!/usr/bin/env bash
#
# nv - Launch sandboxed Neovim in a Docker container
#
# Usage:
#   nv [directory] [-- nvim args...]
#   nv .                    # open current dir
#   nv ~/dev/myproject      # open specific dir
#   nv . -- file.rs         # open specific file in project
#
set -euo pipefail

IMAGE_NAME="nv"
CONTAINER_PREFIX="nv"
VOLUME_NAME="nv-data"

# ── Parse arguments ──────────────────────────────────────────────
TARGET_DIR=""
NVIM_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --)
            shift
            NVIM_ARGS=("$@")
            break
            ;;
        --build)
            echo "Building $IMAGE_NAME image..."
            SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
            rm -rf "$SCRIPT_DIR/nvim-config"
            cp -r "${XDG_CONFIG_HOME:-$HOME/.config}/nvim" "$SCRIPT_DIR/nvim-config"
            cp "${XDG_CONFIG_HOME:-$HOME/.config}/starship.toml" "$SCRIPT_DIR/starship.toml" 2>/dev/null || true
            docker build \
                --build-arg UID="$(id -u)" \
                -t "$IMAGE_NAME" "$SCRIPT_DIR"
            rm -rf "$SCRIPT_DIR/nvim-config" "$SCRIPT_DIR/starship.toml"
            echo "Done."
            exit 0
            ;;
        --rebuild)
            echo "Rebuilding $IMAGE_NAME image (no cache)..."
            SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
            rm -rf "$SCRIPT_DIR/nvim-config"
            cp -r "${XDG_CONFIG_HOME:-$HOME/.config}/nvim" "$SCRIPT_DIR/nvim-config"
            cp "${XDG_CONFIG_HOME:-$HOME/.config}/starship.toml" "$SCRIPT_DIR/starship.toml" 2>/dev/null || true
            docker build --no-cache \
                --build-arg UID="$(id -u)" \
                -t "$IMAGE_NAME" "$SCRIPT_DIR"
            rm -rf "$SCRIPT_DIR/nvim-config" "$SCRIPT_DIR/starship.toml"
            echo "Done."
            exit 0
            ;;
        --shell)
            # Drop into a shell inside the container instead of nvim
            # Useful for installing extra tools, debugging, etc.
            SHELL_MODE=1
            ;;
        --help|-h)
            echo "Usage: nv [directory] [-- nvim args...]"
            echo ""
            echo "Options:"
            echo "  --build     Build the Docker image"
            echo "  --rebuild   Build with --no-cache"
            echo "  --shell     Drop into bash instead of nvim"
            echo "  --help      Show this help"
            echo ""
            echo "Examples:"
            echo "  nv .                  Open current directory"
            echo "  nv ~/dev/project      Open specific directory"
            echo "  nv . -- file.rs       Open a specific file"
            echo "  nv . --shell          Get a shell in the container"
            exit 0
            ;;
        *)
            TARGET_DIR="$1"
            ;;
    esac
    shift
done

# Default to current directory
TARGET_DIR="${TARGET_DIR:-.}"
TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)"

# ── Check image exists ───────────────────────────────────────────
if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    echo "Image '$IMAGE_NAME' not found. Run: nv --build"
    exit 1
fi

# ── Create persistent volumes ────────────────────────────────────
docker volume create "$VOLUME_NAME" &>/dev/null || true
docker volume create "${VOLUME_NAME}-undo" &>/dev/null || true

# ── Container name ───────────────────────────────────────────────
DIR_SLUG="$(basename "$TARGET_DIR" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g')"
CONTAINER_NAME="${CONTAINER_PREFIX}-${DIR_SLUG}-$$"

# ── Mounts ───────────────────────────────────────────────────────
MOUNTS=(
    # The project directory — this is the blast radius
    -v "$TARGET_DIR:/workspace"

    # Persistent nvim data (plugins, mason, undo, shada)
    -v "$VOLUME_NAME:/home/dev/.local/share/nvim"
    -v "${VOLUME_NAME}-undo:/home/dev/.vim/undodir"

    # Git config (read-only)
    -v "$HOME/.gitconfig:/home/dev/.gitconfig:ro"

    # Known hosts so SSH can verify github.com
    -v "$HOME/.ssh/known_hosts:/home/dev/.ssh/known_hosts:ro"

    # SSH agent socket (Docker Desktop for macOS)
    -v /run/host-services/ssh-auth.sock:/run/host-services/ssh-auth.sock

    # oh-my-zsh and zsh config (read-only)
    -v "$HOME/.oh-my-zsh:/home/dev/.oh-my-zsh:ro"
    -v "$HOME/.zshrc:/home/dev/.zshrc:ro"

    # Persistent zsh history (shared with host)
    -v "$HOME/.zsh_history:/home/dev/.zsh_history"

    # Claude Code auth and config
    -v "$HOME/.claude:/home/dev/.claude"
    -v "$HOME/.claude.json:/home/dev/.claude.json"
)

# macos workaround to extract claude login from OS keychain
security find-generic-password -a "$USER" -s "Claude Code-credentials" -w > ~/.claude/.credentials.json
chmod 600 ~/.claude/.credentials.json

# ── Environment ──────────────────────────────────────────────────
ENV_VARS=(
    -e "TERM=${TERM:-xterm-256color}"
    -e "COLORTERM=${COLORTERM:-truecolor}"
    -e "NV_HOST_DIR=$TARGET_DIR"

    # Forward the host SSH agent so the passphrase is only typed once on the host
    -e "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock"
)

# ── Security hardening ───────────────────────────────────────────
SECURITY=(
    # Drop all capabilities, only add back what's needed
    --cap-drop=ALL
    # No new privileges (prevents setuid binaries)
    --security-opt=no-new-privileges
    # No network by default — uncomment next line to enable
    # (you'll want network for LSP downloads, git push/pull, etc.)
    # --network=none
)

# ── Entrypoint override for --shell mode ─────────────────────────
ENTRY=()
if [[ "${SHELL_MODE:-}" == "1" ]]; then
    ENTRY=(--entrypoint /bin/zsh)
    NVIM_ARGS=()
fi

# ── Run ──────────────────────────────────────────────────────────
exec docker run \
    --rm \
    -it \
    --name "$CONTAINER_NAME" \
    "${MOUNTS[@]}" \
    "${ENV_VARS[@]}" \
    "${SECURITY[@]}" \
    "${ENTRY[@]}" \
    "$IMAGE_NAME" \
    "${NVIM_ARGS[@]}"
